# ==============================================================================
# ONE App Server - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================================================================

# === Server Configuration ===
PORT=4000
NODE_ENV=development

# === Database ===
# SQLite for development
DATABASE_URL="file:./dev.db"

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL="postgresql://user:password@localhost:5432/one_app?schema=public"

# === Security - JWT Configuration ===
# IMPORTANT: Generate strong random secrets for production!
# Use: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-change-in-production"

# === CORS Configuration ===
# Comma-separated list of allowed origins
# For production, use your actual domain(s)
CORS_ORIGIN="http://localhost:3000"

# === Web App URL ===
# Used for password reset links and redirects
WEB_BASE_URL="http://localhost:3000"

# === Stripe Configuration ===
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRICE_ID_MONTHLY="price_your_price_id"

# === Google OAuth (Optional - for Google Sign-In) ===
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# === Email Configuration (Resend) ===
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="ONE <hello@oneinseparable.app>"
EMAIL_REPLY_TO="support@oneinseparable.app"

# === Cron Job Authentication ===
# Secret token for authenticating cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-change-in-production"

# === Rate Limiting ===
# Customize rate limiting if needed (values in milliseconds)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=10

# === Logging ===
# LOG_LEVEL="debug"  # debug, info, warn, error
